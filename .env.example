NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000

# Auth
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_CLIENT_SECRET=replace-with-secret-or-secrets-manager-in-aws
COGNITO_DOMAIN=your-domain.auth.us-east-1.amazoncognito.com
COGNITO_REDIRECT_URI=http://localhost:3000/callback.html

# Data + AI
DYNAMODB_PROFILE_TABLE=memflow-user-profiles
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# Code execution
# local  = compile inside this host using gcc or Docker
# remote = forward compile/run requests to another runner service
EXECUTION_MODE=local
RUNNER_API_URL=
ALLOW_LOCAL_EXECUTION=true
PREFER_LOCAL_EXECUTION=true
C_COMPILER=gcc

# Optional local-only shortcut to bypass Cognito while building UI locally.
DEMO_MODE=false
